import "std/io";
import "std/process";
import "std/string" {eq};
import "./cli.zp";
import "./build.zp";
import "./create.zp";
import "./deps.zp";

fun main() Int {
    if process.argc() < 2 {
        cli.usage(process.argv(0));
        return 1;
    }

    var cmd: String = process.argv(1);

    if eq(cmd, "build") {
        var options: cli.CliOptions = cli.parseBuildRunOptions(cmd);
        return build.buildProject(options);
    }

    if eq(cmd, "run") {
        var options: cli.CliOptions = cli.parseBuildRunOptions(cmd);
        return build.runProject(options);
    }

    if eq(cmd, "new") {
        if process.argc() < 3 {
            io.eprintln("missing project name");
            cli.usage(process.argv(0));
            return 1;
        }
        if process.argc() > 3 {
            io.eprintln("too many arguments for new");
            cli.usage(process.argv(0));
            return 1;
        }
        return create.createProject(process.argv(2));
    }
    
    if eq(cmd, "add") {
        if process.argc() < 3 {
            io.eprintln("missing git url");
            cli.usage(process.argv(0));
            return 1;
        }
        return deps.addDependency(process.argv(2));
    }

    if eq(cmd, "--version") {
        io.println("thor 0.3.0");
        return 0;
    }

    if eq(cmd, "--help") || eq(cmd, "-h") {
        cli.usage(process.argv(0));
        return 0;
    }

    io.eprintln("unknown command: " + cmd);
    cli.usage(process.argv(0));
    return 1;
}
